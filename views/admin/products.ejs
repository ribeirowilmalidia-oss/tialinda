<% const title='Produtos'; %><%- include('_head') %>

<header class="admin-header">
  <div>
    <h1>Produtos &amp; Estoque</h1>
    <p class="muted"><%= products.length %> produto(s) cadastrado(s)</p>
  </div>
  <a href="/admin/produto/novo" class="btn btn-primary">+ Novo produto</a>
</header>

<div class="card">
  <table class="t t-stretch">
    <thead><tr><th></th><th>Produto</th><th>Categoria</th><th>Preço</th><th>Estoque</th><th></th></tr></thead>
    <tbody>
      <% products.forEach(p => { %>
        <tr>
          <td><div class="thumb" style="background-image:url('<%= p.image_url %>')"></div></td>
          <td><strong><%= p.name %></strong>
            <% if (p.size) { %><span style="display:inline-block;background:#c4593a;color:#fff;padding:1px 8px;border-radius:10px;font-size:11px;font-weight:600;margin-left:6px;letter-spacing:0.5px"><%= p.size %></span><% } %>
            <% if (p.color) { %><span style="display:inline-flex;align-items:center;gap:5px;background:#f4ede0;color:#5a4a2f;padding:1px 8px;border-radius:10px;font-size:11px;font-weight:600;margin-left:6px"><% if (p.color_hex) { %><span style="width:10px;height:10px;border-radius:50%;background:<%= p.color_hex %>;box-shadow:inset 0 0 0 1px rgba(0,0,0,.15)"></span><% } %><%= p.color %></span><% } %>
            <br><small class="muted"><%= p.slug %></small>
            <% if (p.family) { %><br><small style="color:#7a5c33;font-size:10px">👥 <%= p.family %></small><% } %></td>
          <td><%= (CATEGORIES.find(c=>c.slug===p.category)||{}).name %></td>
          <td>
            <%= brl(p.price) %>
            <% if (p.price_usd) { %><br><small style="color:#c4593a">💵 US$ <%= Number(p.price_usd).toFixed(2) %></small><% } %>
          </td>
          <td><strong class="<%= p.stock < 5 ? 'danger' : p.stock < 10 ? 'warn' : '' %>"><%= p.stock %></strong></td>
          <td class="actions">
            <a href="/admin/produto/<%= p.id %>" class="btn btn-soft btn-sm">Editar</a>
            <form action="/admin/produto/<%= p.id %>/excluir" method="post" onsubmit="return confirm('Excluir este produto?')">
              <button class="btn btn-danger btn-sm">Excluir</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('_foot') %>
