<% const title = p ? 'Editar produto' : 'Novo produto'; %><%- include('_head') %>

<header class="admin-header">
  <h1><%= p ? 'Editar produto' : 'Novo produto' %></h1>
  <a href="/admin/produtos" class="btn btn-ghost btn-sm">← Voltar</a>
</header>

<form action="/admin/produto/salvar" method="post" class="card form-card">
  <% if (p) { %><input type="hidden" name="id" value="<%= p.id %>"><% } %>
  <label>Nome do produto <input name="name" value="<%= p ? p.name : '' %>" required></label>

  <div class="row-2">
    <label>Categoria
      <select name="category" required>
        <% CATEGORIES.forEach(c => { %>
          <option value="<%= c.slug %>" <%= p && p.category===c.slug ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </label>
    <label>Preço (R$) <input name="price" type="number" step="0.01" min="0" value="<%= p ? p.price : '' %>" required></label>
  </div>

  <div class="row-2">
    <label>Estoque <input name="stock" type="number" min="0" value="<%= p ? p.stock : 0 %>" required></label>
    <label class="check-label"><input type="checkbox" name="featured" value="1" <%= p && p.featured ? 'checked' : '' %>> Destacar na home</label>
  </div>

  <label>URL da imagem <input name="image_url" value="<%= p ? p.image_url : '' %>" placeholder="https://..."></label>
  <label>Descrição <textarea name="description" rows="5"><%= p ? p.description : '' %></textarea></label>

  <div class="form-actions">
    <button class="btn btn-primary">Salvar</button>
    <a href="/admin/produtos" class="btn btn-ghost">Cancelar</a>
  </div>
</form>

<%- include('_foot') %>
