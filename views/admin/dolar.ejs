<% const title='Reajuste pelo Dólar'; %><%- include('_head') %>

<header class="admin-header">
  <h1>Reajuste mensal pelo dólar</h1>
  <p class="muted">Cotação travada a cada mês (atualiza automaticamente no dia 1º). Preços da loja acompanham a cotação do mês corrente. O valor cadastrado não muda — o ajuste é aplicado em tempo real.</p>
</header>

<div class="kpi-grid">
  <div class="kpi">
    <small>Cotação do mês (travada)</small>
    <strong><%= cotacao ? 'R$ ' + Number(cotacao).toFixed(4).replace('.', ',') : '—' %></strong>
    <p class="muted" style="margin:6px 0 0;font-size:12px">
      Mês: <strong><%= mesAtual || '—' %></strong> ·
      Fonte:
      <% if (fonte === 'dolarpy') { %>
        <a href="https://www.dolarpy.com.br/" target="_blank" rel="noopener">dolarpy.com.br</a>
      <% } else if (fonte === 'awesomeapi') { %>
        awesomeapi
      <% } else if (fonte && fonte.startsWith('bcb')) { %>
        BCB (PTAX)
      <% } else { %>
        <%= fonte || '—' %>
      <% } %>
      <% if (typeof cotacaoSpot !== 'undefined' && cotacaoSpot && cotacao && Math.abs(cotacaoSpot-cotacao)>0.001) { %>
        <br>Cotação de hoje (informativa): R$ <%= Number(cotacaoSpot).toFixed(4).replace('.', ',') %>
      <% } %>
    </p>
  </div>
  <div class="kpi <%= ativo ? 'kpi-accent' : '' %>">
    <small>Fator aplicado</small>
    <strong><%= ativo ? factor.toFixed(4) + '×' : '1,0000× off' %></strong>
    <p class="muted" style="margin:6px 0 0;font-size:12px">
      <% if (ativo && cotacao) { %>
        (<%= cotacao.toFixed(2) %> ÷ <%= referencia.toFixed(2) %>) × (1 + <%= (markup*100).toFixed(1) %>%)
      <% } else { %>
        Desativado — preços do cadastro
      <% } %>
    </p>
  </div>
  <div class="kpi">
    <small>Exemplo: R$ 100 cadastro</small>
    <strong>R$ <%= (100 * (ativo ? factor : 1)).toFixed(2).replace('.', ',') %></strong>
    <p class="muted" style="margin:6px 0 0;font-size:12px">Preço exibido na loja</p>
  </div>
  <div class="kpi">
    <small>Última atualização</small>
    <strong style="font-size:14px"><%= ultimaAtualizacao ? new Date(ultimaAtualizacao).toLocaleString('pt-BR') : '—' %></strong>
    <form method="POST" action="/admin/dolar/atualizar-agora" style="margin-top:8px">
      <button type="submit" style="background:transparent;border:1px solid #ddd;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:12px">↻ Buscar agora</button>
    </form>
  </div>
</div>

<div class="admin-grid" style="margin-top:24px">
  <section class="card">
    <div class="card-head"><h2>Configurações</h2></div>
    <form method="POST" action="/admin/dolar/salvar" style="padding:6px 4px">

      <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:#f7f4ee;border-radius:10px;margin-bottom:18px">
        <input type="checkbox" name="ativo" id="ativo" value="1" <%= ativo ? 'checked' : '' %> style="width:20px;height:20px;cursor:pointer">
        <label for="ativo" style="cursor:pointer;flex:1">
          <strong>Ativar reajuste pelo dólar</strong><br>
          <span class="muted" style="font-size:13px">Quando desmarcado, preços aparecem exatamente como cadastrados.</span>
        </label>
      </div>

      <div style="margin-bottom:16px">
        <label style="display:block;font-weight:600;margin-bottom:6px">Cotação de referência (R$)</label>
        <input type="number" step="0.0001" min="1" max="20" name="referencia" value="<%= referencia.toFixed(4) %>" required style="width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;font-size:15px">
        <small class="muted" style="display:block;margin-top:4px">Cotação do dólar no dia em que você definiu os preços atuais. Se o dólar hoje estiver acima, preços sobem proporcionalmente.</small>
      </div>

      <div style="margin-bottom:20px">
        <label style="display:block;font-weight:600;margin-bottom:6px">Markup adicional (%)</label>
        <input type="number" step="0.1" min="-50" max="200" name="markup" value="<%= (markup*100).toFixed(1) %>" required style="width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;font-size:15px" oninput="this.value=this.value">
        <small class="muted" style="display:block;margin-top:4px">Percentual extra aplicado sobre o fator do dólar. Use 0 = cotação pura, 5 = +5%, 10 = +10%.</small>
      </div>

      <input type="hidden" name="_markup_pct" value="1">
      <button type="submit" class="btn btn-primary">Salvar configurações</button>
    </form>

    <form method="POST" action="/admin/dolar/usar-cotacao-atual" style="margin:14px 0 0;padding:14px;border-top:1px dashed #e6e2d8">
      <button type="submit" class="btn btn-soft" onclick="return confirm('Definir a cotação de referência para R$ <%= cotacao ? cotacao.toFixed(4) : 0 %>? Os preços vão ficar igual ao cadastro a partir de agora.')" style="width:100%">
        📌 Congelar preços atuais (usar cotação de hoje como referência)
      </button>
    </form>
  </section>

  <section class="card">
    <div class="card-head"><h2>Como funciona</h2></div>
    <ol style="line-height:1.7;padding:0 4px 4px 22px;font-size:14px">
      <li>Cadastre os produtos com preços em BRL (ou preencha <code>price_usd</code> para preços em dólar).</li>
      <li>Defina a <strong>cotação de referência</strong> = valor do dólar no dia em que definiu os preços.</li>
      <li><strong>Uma vez por mês</strong>, no primeiro acesso do mês (normalmente dia 1º), o site busca a cotação USD/BRL em <strong><a href="https://www.dolarpy.com.br/" target="_blank">dolarpy.com.br</a></strong> e trava esse valor até o próximo mês. Fallbacks: awesomeapi e Banco Central.</li>
      <li>O fator = cotação_mês ÷ cotação_referência × (1 + markup).</li>
      <li>Durante o mês inteiro os preços permanecem estáveis. No dia 1º do próximo mês, a cotação é atualizada automaticamente.</li>
      <li>Você pode forçar uma nova cotação a qualquer momento clicando em "↻ Buscar agora".</li>
      <li>O preço no banco de dados <strong>nunca é alterado</strong>. Se desativar o reajuste, tudo volta ao normal.</li>
    </ol>
    <p class="muted" style="margin-top:14px;font-size:13px;padding:0 4px">💡 Dica: se você importa/compra em dólar, defina a referência = cotação do dia em que você comprou o estoque. Assim, se o dólar disparar, você não vende no prejuízo.</p>
  </section>
</div>

<script>
// Converte o input markup (que o usuário digita em %) para o fator decimal antes de submeter
document.querySelector('form[action="/admin/dolar/salvar"]').addEventListener('submit', function(e){
  const mkInput = this.querySelector('[name=markup]');
  const pct = parseFloat(String(mkInput.value).replace(',', '.')) || 0;
  mkInput.value = (pct / 100).toString();
});
</script>

<%- include('_foot') %>
