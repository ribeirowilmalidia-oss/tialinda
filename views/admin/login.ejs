<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Admin · Tia Linda</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cormorant+Garamond:wght@600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">
</head>
<body class="admin-body">
<div class="admin-login">
  <div class="login-card">
    <img src="/img/logo-emblem.png" alt="Tia Linda" style="height:90px;width:auto;border-radius:10px;margin:0 auto 16px;display:block">
    <h1>Painel Tia Linda</h1>
    <p class="muted">Acesso restrito da equipe comercial</p>
    <form method="post" action="/admin/login">
      <label>Senha de acesso
        <input name="password" type="password" required autofocus>
      </label>
      <% if (error) { %><p class="alert"><%= error %></p><% } %>
      <button class="btn btn-primary btn-block">Entrar</button>
    </form>
    <p class="muted small">Dica: senha padrão <code>tialinda2026</code></p>
  </div>
</div>
</body>
</html>
